{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "rootDir": "./build",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["build/*"],
      "@bot/*": ["build/bot/*"],
      "@modules/*": ["build/bot/modules/*"],
      "@internal/*": ["build/bot/internalSetup/*"],
      "@bot/types": ["build/bot/types"],
      "@webui/*": ["build/webui/*"]
    }
  },
  "include": ["./build/**/*.ts"],
  "exclude": ["node_modules","dist","build/**/disabled","build/**/*.disabled"]
}
